    for wx in (1.28, -1.28):
        _whl(wx, 0.52, 3.10, 0.52, 0.28)
    for ax in (-2.80, -4.00):
        for wx in (1.36, -1.36):
            _whl(wx, 0.52, ax, 0.52, 0.28)
    glPopMatrix()

def draw_levante(pp, fw, rg, _=0.):
