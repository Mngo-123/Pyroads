    for wz, wx in ((1.02, 1.02), (1.02, -1.02), (-1.68, 1.02), (-1.68, -1.02)):
        _whl(wx, 0.32, wz, 0.32, 0.22)
    glPopMatrix()

def draw_gemini2(pp, fw, rg, _=0.):
