STRIPS=12; STRIP_W=11.0
FLAT_R=26.0

def _blended_h(h_raw, ry, edge_d, is_bridge):
    if is_bridge:
        return WATER_Y
    if edge_d < FLAT_R:
        t=edge_d/FLAT_R; bt=t*t*(3-2*t)
        return ry*(1-bt)+h_raw*bt
    return h_raw

def draw_terrain(road,ci):
    s=max(0,ci-DRAW_BH); e=ci+DRAW_AH; half=ROAD_W*.5
    glNormal3f(0,1,0)
    for side in(-1.,1.):
        for k in range(STRIPS):
            id_=half+k*STRIP_W; od_=id_+STRIP_W
            glBegin(GL_QUAD_STRIP)
            for i in range(s,e+1):
                p,_,n=road.get(i); ry=float(p[1]); br=road.bridge(i)
                for d in(id_,od_):
                    pos=p+n*(side*d)
                    px2,pz2=float(pos[0]),float(pos[2])
                    h_raw=th_c(px2,pz2)
                    h=_blended_h(h_raw, ry, d-half, br)
                    h=max(WATER_Y,h)
                    if h<=WATER_Y+0.05: glColor3f(*WCOL)
                    else: glColor3f(*tcol(h, _cn(px2,pz2)<COAST_BEACH))
                    glVertex3f(px2,h,pz2)
            glEnd()

def draw_road(road,ci):
    s=max(0,ci-DRAW_BH); e=ci+DRAW_AH; half=ROAD_W*.5
    glDisable(GL_LIGHTING)
    glBegin(GL_QUAD_STRIP)
    for i in range(s,e+1):
        p,_,n=road.get(i)
        glColor3f(*((0.50,0.47,0.42) if road.bridge(i) else (0.28,0.28,0.30)))
        l=p-n*half; r=p+n*half
        glVertex3f(float(l[0]),float(l[1]),float(l[2]))
        glVertex3f(float(r[0]),float(r[1]),float(r[2]))
    glEnd()
    glColor3f(0.85,0.85,0.85); glLineWidth(2.)
    for sd in(-1.,1.):
        glBegin(GL_LINE_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); ep=p+n*(sd*half)
            glVertex3f(float(ep[0]),float(ep[1]),float(ep[2]))
        glEnd()
    glColor3f(0.92,0.88,0.60); glLineWidth(1.5)
    for i in range(s,e):
        if(i%5)<3:
            p0=road.get(i)[0]; p1=road.get(i+1)[0]
            glBegin(GL_LINES)
            glVertex3f(float(p0[0]),float(p0[1]),float(p0[2]))
            glVertex3f(float(p1[0]),float(p1[1]),float(p1[2]))
            glEnd()
    glLineWidth(1.); glEnable(GL_LIGHTING)

# ═══════════════════════════════════════════════════════
#  BRIDGE MODELS  –  stone brick arch · concrete arch
#  Type assigned deterministically per-span via position hash.
#  Pillar indices are snapped to absolute grid (% step == 0)
#  so they never shift as the draw window moves.
# ═══════════════════════════════════════════════════════

def _brhash(x,z): return int((int(x*7)^(int(z*13)*31))&0x7FFFFFFF)
def _bridge_type(road,si):
    p=road.get(si)[0]
    return _brhash(float(p[0]),float(p[2]))%2   # 0=stone brick  1=concrete

# ── shared box (bottom face at y, centred x/z) ──────────
def _qbox(x,y,z,w,h,d):
    hw,hh,hd=w*.5,h*.5,d*.5; cy=y+hh
    faces=(
        ( 0,0, 1,(-hw,-hh, hd),( hw,-hh, hd),( hw,hh, hd),(-hw,hh, hd)),
        ( 0,0,-1,( hw,-hh,-hd),(-hw,-hh,-hd),(-hw,hh,-hd),( hw,hh,-hd)),
        ( 1,0, 0,( hw,-hh,-hd),( hw,-hh, hd),( hw,hh, hd),( hw,hh,-hd)),
        (-1,0, 0,(-hw,-hh, hd),(-hw,-hh,-hd),(-hw,hh,-hd),(-hw,hh, hd)),
        ( 0,1, 0,(-hw, hh, hd),( hw, hh, hd),( hw,hh,-hd),(-hw,hh,-hd)),
        ( 0,-1,0,(-hw,-hh,-hd),( hw,-hh,-hd),( hw,-hh,hd),(-hw,-hh,hd)),
    )
    glBegin(GL_QUADS)
    for fnx,fny,fnz,v0,v1,v2,v3 in faces:
        glNormal3f(fnx,fny,fnz)
        for vx,vy,vz in(v0,v1,v2,v3): glVertex3f(x+vx,cy+vy,z+vz)
    glEnd()

def _arch_curve(cx,bot,cz,w,h,btype):
    """Draw a single arch pier. btype 0=stone, 1=concrete.
    The arch is approximated with 3 visual tiers to imply a curved soffit."""
    if btype==0:
        # ── stone brick arch pier ──────────────────────────────
        # Footing (wide rubble base)
        glColor3f(0.52,0.47,0.40); _qbox(cx,bot,cz, w*1.50,h*0.12,w*1.30)
        # Lower shaft (tapers slightly)
        glColor3f(0.60,0.55,0.46); _qbox(cx,bot+h*0.12,cz, w*1.20,h*0.42,w*1.10)
        # Springer stones (darker brick band at arch spring)
        glColor3f(0.48,0.43,0.36); _qbox(cx,bot+h*0.54,cz, w*1.30,h*0.08,w*1.20)
        # Spandrel fill (from spring to deck soffit) – slightly lighter coursed stone
        glColor3f(0.64,0.59,0.50); _qbox(cx,bot+h*0.62,cz, w*1.15,h*0.30,w*1.05)
        # Cap stone (proud, dark)
        glColor3f(0.46,0.42,0.36); _qbox(cx,bot+h*0.92,cz, w*1.35,h*0.08,w*1.25)
    else:
        # ── concrete arch pier ────────────────────────────────
        # Base pad
        glColor3f(0.65,0.64,0.62); _qbox(cx,bot,cz, w*1.40,h*0.10,w*1.20)
        # Tapered shaft
        glColor3f(0.72,0.71,0.69); _qbox(cx,bot+h*0.10,cz, w*1.10,h*0.50,w*0.95)
        # Arch haunch band (curved bottom of arch, implied by recessed colour)
        glColor3f(0.62,0.61,0.59); _qbox(cx,bot+h*0.60,cz, w*1.20,h*0.08,w*1.05)
        # Spandrel (solid concrete above arch)
        glColor3f(0.74,0.73,0.71); _qbox(cx,bot+h*0.68,cz, w*1.08,h*0.26,w*0.95)
        # Bearing pad
        glColor3f(0.60,0.59,0.57); _qbox(cx,bot+h*0.94,cz, w*1.30,h*0.06,w*1.15)

# ── spandrel walls (sides of arch deck) ──────────────────
def _stone_parapet(road,s,e,half):
    """Coursed stone parapet walls with coping stones."""
    half2=half+0.14
    LIFT=0.04   # keep all vertices above road deck to avoid z-fighting
    for ss in(-1.,1.):
        glColor3f(0.58,0.53,0.45)
        glBegin(GL_QUAD_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); ep=p+n*(ss*half2); ry=float(p[1])+LIFT
            glNormal3f(float(ss*n[0]),0.,float(ss*n[2]))
            glVertex3f(float(ep[0]),ry,float(ep[2]))
            glVertex3f(float(ep[0]),ry+0.72,float(ep[2]))
        glEnd()
        glColor3f(0.50,0.46,0.38)
        glBegin(GL_QUAD_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); ry=float(p[1])+LIFT
            inner=p+n*(ss*(half+0.04)); outer=p+n*(ss*(half2+0.14))
            glNormal3f(0.,1.,0.)
            glVertex3f(float(inner[0]),ry+0.72,float(inner[2]))
            glVertex3f(float(outer[0]),ry+0.72,float(outer[2]))
        glEnd()
        glColor3f(0.56,0.51,0.43)
        glBegin(GL_QUAD_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); op=p+n*(ss*(half2+0.14)); ry=float(p[1])+LIFT
            glNormal3f(float(ss*n[0]),0.,float(ss*n[2]))
            glVertex3f(float(op[0]),ry,float(op[2]))
            glVertex3f(float(op[0]),ry+0.72,float(op[2]))
        glEnd()

def _concrete_parapet(road,s,e,half):
    """Concrete bridge parapet with recessed panel detail."""
    half2=half+0.18
    LIFT=0.04
    for ss in(-1.,1.):
        glColor3f(0.76,0.75,0.73)
        glBegin(GL_QUAD_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); ep=p+n*(ss*half2); ry=float(p[1])+LIFT
            glNormal3f(float(ss*n[0]),0.,float(ss*n[2]))
            glVertex3f(float(ep[0]),ry,float(ep[2]))
            glVertex3f(float(ep[0]),ry+0.80,float(ep[2]))
        glEnd()
        glColor3f(0.68,0.67,0.65)
        glBegin(GL_QUAD_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); ry=float(p[1])+LIFT
            inner=p+n*(ss*(half+0.06)); outer=p+n*(ss*(half2+0.12))
            glNormal3f(0.,1.,0.)
            glVertex3f(float(inner[0]),ry+0.80,float(inner[2]))
            glVertex3f(float(outer[0]),ry+0.80,float(outer[2]))
        glEnd()
        glColor3f(0.72,0.71,0.69)
        glBegin(GL_QUAD_STRIP)
        for i in range(s,e+1):
            p,_,n=road.get(i); op=p+n*(ss*(half2+0.12)); ry=float(p[1])+LIFT
            glNormal3f(float(ss*n[0]),0.,float(ss*n[2]))
            glVertex3f(float(op[0]),ry,float(op[2]))
            glVertex3f(float(op[0]),ry+0.80,float(op[2]))
        glEnd()

def draw_bridges(road,ci):
    """Draw all bridge structures in visible range."""
    s=max(0,ci-DRAW_BH); e=ci+DRAW_AH; half=ROAD_W*.5
    glEnable(GL_LIGHTING)
    # Push bridge geometry slightly away from camera so it never z-fights with road deck
    glEnable(GL_POLYGON_OFFSET_FILL); glPolygonOffset(2.,2.)
    PILLAR_STEP=6

    i=s
    while i<=e:
        if not road.bridge(i): i+=1; continue
        span_s=i
        while i<=e and road.bridge(i): i+=1
        span_e=i-1
        if span_e<=span_s: continue

        btype=_bridge_type(road,span_s)

        # ── pillars snapped to absolute grid ─────────────
        anchor=span_s-(span_s%PILLAR_STEP)
        for j in range(anchor,span_e+1,PILLAR_STEP):
            if j<span_s: continue
            p,_,_=road.get(j)
            px2,pz2=float(p[0]),float(p[2])
            g=th_c(px2,pz2)
            bot=min(g,WATER_Y-1.2)
            # stop pillar 0.14 m below deck so cap never pokes through road surface
            h=max(0.8,float(p[1])-bot-0.14)
            _arch_curve(px2,bot,pz2,1.5,h,btype)

        # ── parapets: start 0.04 m above road to avoid z-fight ──
        if btype==0: _stone_parapet(road,span_s,span_e,half)
        else:        _concrete_parapet(road,span_s,span_e,half)

    glDisable(GL_POLYGON_OFFSET_FILL)
    glEnable(GL_LIGHTING)

# ═══════════════════════════════════════════════════════
#  TREES  – denser, cached forest influence, low-poly
# ═══════════════════════════════════════════════════════
TCELL=16.; TREE_R=140.

def _thash(ci,cj): return int((ci*73856093)^(cj*19349663))&0x7FFFFFFF

def _cyl(x,y,z,r,h,s=5):   # 5-sided trunk (was 7)
    glBegin(GL_QUAD_STRIP)
    for j in range(s+1):
        a=2*math.pi*j/s; ca=math.cos(a); sa=math.sin(a)
        glNormal3f(ca,0,sa); glVertex3f(x+r*ca,y,z+r*sa); glVertex3f(x+r*ca,y+h,z+r*sa)
    glEnd()

def _cone(x,y,z,r,h,s=7):  # 7-sided cone (was 9)
    inv=1./math.sqrt(h*h+r*r); un=h*inv
    glBegin(GL_TRIANGLE_FAN); glNormal3f(0,1,0); glVertex3f(x,y+h,z)
    for j in range(s+1):
        a=2*math.pi*j/s; ca=math.cos(a); sa=math.sin(a)
        glNormal3f(ca*un,r*inv,sa*un); glVertex3f(x+r*ca,y,z+r*sa)
    glEnd()

def _dome(x,y,z,r,h):
    s=8   # was 10
    glBegin(GL_TRIANGLE_FAN); glNormal3f(0,1,0); glVertex3f(x,y+h,z)
    for j in range(s+1):
        a=2*math.pi*j/s
        glNormal3f(math.cos(a),0.4,math.sin(a))
        glVertex3f(x+r*.85*math.cos(a),y+h*.3,z+r*.85*math.sin(a))
    glEnd()
    glBegin(GL_QUAD_STRIP)
    for j in range(s+1):
        a=2*math.pi*j/s; ca=math.cos(a); sa=math.sin(a)
        glNormal3f(ca,0,sa)
        glVertex3f(x+r*.85*ca,y+h*.3,z+r*.85*sa)
        glVertex3f(x+r*ca,y,z+r*sa)
    glEnd()

TREE_ROAD_MARGIN = ROAD_W * 3.5

# ═══════════════════════════════════════════════════════
#  FOREST ZONES  –  dense clusters placed on grid
# ═══════════════════════════════════════════════════════
FOREST_CELL = 750.0
FOREST_PROB = 0.42

def _fhash(ci,cj):
    return int((ci*92837111)^(cj*689287499))&0x7FFFFFFF

def _forest_influence(tx,tz):
    fc_i=int(math.floor(tx/FOREST_CELL))
    fc_j=int(math.floor(tz/FOREST_CELL))
    best=0.0
    for di in range(-1,2):
        for dj in range(-1,2):
            ci=fc_i+di; cj=fc_j+dj
            rng=random.Random(_fhash(ci,cj))
            if rng.random()>FOREST_PROB: continue
            fx=ci*FOREST_CELL+rng.uniform(80,FOREST_CELL-80)
            fz=cj*FOREST_CELL+rng.uniform(80,FOREST_CELL-80)
            fr=rng.uniform(70,130)
            d=math.sqrt((tx-fx)**2+(tz-fz)**2)
            if d<fr:
                t=1.0-d/fr; best=max(best,t*t*(3-2*t))
    return best

# Cache forest influence per tree-grid cell (key = (ci,cj))
_FIC: dict = {}
def _fi_cached(ci,cj):
    k=(ci,cj)
    v=_FIC.get(k)
    if v is None:
        if len(_FIC)>12000: _FIC.clear()
        tx=(ci+0.5)*TCELL; tz=(cj+0.5)*TCELL
        _FIC[k]=v=_forest_influence(tx,tz)
    return v


def draw_trees(player_pos, road, near_seg):
    px,pz=float(player_pos[0]),float(player_pos[2])
    R2=TREE_R*TREE_R
    i0=int(math.floor((px-TREE_R)/TCELL)); i1=int(math.floor((px+TREE_R)/TCELL))+1
    j0=int(math.floor((pz-TREE_R)/TCELL)); j1=int(math.floor((pz+TREE_R)/TCELL))+1

    lo=max(0,near_seg-50); hi=near_seg+50
    road.get(hi+5)
    road_pts=[(float(road.get(i)[0][0]),float(road.get(i)[0][2])) for i in range(lo,hi)]
    M2=TREE_ROAD_MARGIN**2

    for ci in range(i0,i1):
        for cj in range(j0,j1):
            rng=random.Random(_thash(ci,cj))
            tx=ci*TCELL+rng.uniform(1.,TCELL-1.)
            tz=cj*TCELL+rng.uniform(1.,TCELL-1.)
            if(tx-px)**2+(tz-pz)**2>R2: continue
            if _mac(tx,tz)<-0.20: continue
            gnd=th_c(tx,tz)
            if gnd<WATER_Y+0.5: continue
            if gnd>200.0:
                if rng.random()>max(0.0,1.0-(gnd-200.0)/300.0): continue
            fi=_fi_cached(ci,cj)
            # open land 38%, deep forest 92%
            if rng.random()>0.38+fi*0.54: continue
            if any((tx-rpx)**2+(tz-rpz)**2<M2 for rpx,rpz in road_pts): continue
            scale=1.0+fi*0.55
            tkh=rng.uniform(1.4,2.6)*scale
            crr=rng.uniform(1.2,2.0)*scale
            crh=rng.uniform(2.5,4.2)*scale
            conifer=(rng.random()<(0.38+fi*0.30))
            glColor3f(0.36+rng.random()*.08,0.22+rng.random()*.06,0.10+rng.random()*.04)
            _cyl(tx,gnd,tz,0.20*scale,tkh)
            if conifer:
                glColor3f(0.10+rng.random()*.06,0.28+rng.random()*.10,0.10+rng.random()*.04)
                _cone(tx,gnd+tkh,tz,crr*.70,crh*1.30)
            else:
                glColor3f(0.20+rng.random()*.10,0.30+rng.random()*.10,0.10+rng.random()*.06)
                _dome(tx,gnd+tkh,tz,crr,crh*.80)

# ═══════════════════════════════════════════════════════
#  VEHICLE PRIMITIVES
# ═══════════════════════════════════════════════════════
def _box(cx,cy,cz,w,h,d):
    hw,hh,hd=w*.5,h*.5,d*.5
    fs=(( 0,0,1,(-hw,-hh,hd),(hw,-hh,hd),(hw,hh,hd),(-hw,hh,hd)),
        ( 0,0,-1,(hw,-hh,-hd),(-hw,-hh,-hd),(-hw,hh,-hd),(hw,hh,-hd)),
        ( 1,0,0,(hw,-hh,-hd),(hw,-hh,hd),(hw,hh,hd),(hw,hh,-hd)),
        (-1,0,0,(-hw,-hh,hd),(-hw,-hh,-hd),(-hw,hh,-hd),(-hw,hh,hd)),
        ( 0,1,0,(-hw,hh,hd),(hw,hh,hd),(hw,hh,-hd),(-hw,hh,-hd)),
        ( 0,-1,0,(-hw,-hh,-hd),(hw,-hh,-hd),(hw,-hh,hd),(-hw,-hh,hd)))
    glBegin(GL_QUADS)
    for nx,ny,nz,v0,v1,v2,v3 in fs:
        glNormal3f(nx,ny,nz)
        for vx,vy,vz in(v0,v1,v2,v3): glVertex3f(cx+vx,cy+vy,cz+vz)
    glEnd()

def _whl(cx,cy,cz,r,w,s=14):
    hw=w*.5; TP=2*math.pi
    glBegin(GL_QUAD_STRIP)
    for j in range(s+1):
        a=TP*j/s; ca=math.cos(a); sa=math.sin(a)
        glNormal3f(0,ca,sa)
        glVertex3f(cx-hw,cy+r*ca,cz+r*sa); glVertex3f(cx+hw,cy+r*ca,cz+r*sa)
    glEnd()
    for sx,wd in((-1,1),(1,-1)):
        glBegin(GL_TRIANGLE_FAN); glNormal3f(float(sx),0,0); glVertex3f(cx+sx*hw,cy,cz)
        for j in range(s+1):
            a=wd*TP*j/s; glVertex3f(cx+sx*hw,cy+r*math.cos(a),cz+r*math.sin(a))
        glEnd()

def _vm(pp,fw,rg):
    """Push vehicle matrix. Local +Z=forward, +X=right, +Y=up.
    cross(rg,fw) gives the correct upward normal (not cross(fw,rg) which points down)."""
    up=np.cross(rg,fw)
    ul=np.linalg.norm(up)
    if ul>1e-6: up/=ul
    m=(float(rg[0]),float(rg[1]),float(rg[2]),0,
       float(up[0]),float(up[1]),float(up[2]),0,
       float(fw[0]),float(fw[1]),float(fw[2]),0,
       float(pp[0]),float(pp[1]),float(pp[2]),1)
    glPushMatrix(); glMultMatrixf(m)

# ─────────────────────────────────────────────────────────
#  NOTE ON FLIPPING car / coach / truck
#  Negating BOTH fw and rg rotates 180° around the up-axis.
#  cross(-fw, -rg) = cross(fw, rg) so the up vector is unchanged.
#  This flips the model to face the direction of travel.
# ─────────────────────────────────────────────────────────

