    'civic':     dict(cb=10,cu=3.8,wb=2.6,ms=62,mr=16,ac=22,br=30,dr=1.0, gd=0.05,fwd_h=1.08,fwd_z=0.55),
    'gemini2':   dict(cb=22,cu=8.0,wb=7.5,ms=22,mr= 7,ac= 4,br= 9,dr=0.55,gd=0.06,fwd_h=1.52,fwd_z=4.60),
    'levante':   dict(cb=26,cu=9.0,wb=7.5,ms=20,mr= 6,ac= 4,br= 9,dr=0.55,gd=0.06,fwd_h=1.52,fwd_z=4.90),
    'daf':       dict(cb=26,cu=9.0,wb=5.5,ms=24,mr= 7,ac= 4,br=10,dr=0.58,gd=0.06,fwd_h=2.20,fwd_z=4.00),
    'honda_cb':  dict(cb= 8,cu=2.8,wb=1.5,ms=60,mr=18,ac=22,br=30,dr=1.10,gd=0.03,fwd_h=1.00,fwd_z=0.45),
}
VNAMES=['focus','civic','gemini2','levante','daf','honda_cb']

# ═══════════════════════════════════════════════════════
#  UK MOORLAND TERRAIN  – realistic heights
#  Valley floors ~0-10 m · moorland 10-120 m
#  High fell 80-320 m  · Summit tops 200-620 m
# ═══════════════════════════════════════════════════════
def th(x,z):
    """UK landscape: ocean → beach → valley → moorland → high fell → summit."""
    cn=_cn(x,z)
    if cn<COAST_SEA:                                  # open sea
        d=min(1.0,(COAST_SEA-cn)/0.22)
        return WATER_Y-1.0-d*9.0
    if cn<COAST_BEACH:                                # beach / dune strip
        t=(cn-COAST_SEA)/(COAST_BEACH-COAST_SEA)
        return WATER_Y+0.05+t*3.5
    inland_s=min(1.0,(cn-COAST_BEACH)/0.12)          # gently lower terrain near coast
    mac=pn(x*0.0014,z*0.0014)
    hil=pn(x*0.006, z*0.006, oc=3, pe=0.48)
    mic=pn(x*0.055, z*0.055)
    if mac<-0.48: return (-3.0+mac*4.0)*max(0.2,inland_s)  # inland lake (very rare)
    if mac<0.08:
        t=(mac+0.28)/0.36
        return (hil*(3.0+t*7.0)+mic*0.5)*inland_s
    if mac<0.40:
        t=(mac-0.08)/0.32
        return hil*(20.0+t*60.0)+mic*3.0+mac*20.0
    if mac<0.65:
        t=(mac-0.40)/0.25
        return hil*(80.0+t*150.0)+mic*8.0+mac*40.0
    t=min(1.0,(mac-0.65)/0.20)
    return hil*(200.0+t*300.0)+mic*15.0+mac*60.0

def _mac(x,z):
    """Biome value. Only open ocean (cn < COAST_SEA) triggers bridge/water mode.
    Beach and coast are dry land. Inland lakes use mac < -0.40 (rarer than before)."""
    cn=_cn(x,z)
    if cn<COAST_SEA: return -0.60      # true ocean → bridge
    if cn<COAST_BEACH: return -0.10    # beach/sand → drive on surface, no bridge
    v=pn(x*0.0014,z*0.0014)
    # remap so lakes only appear at the very bottom of the distribution
    if v<-0.48: return -0.60           # inland lake (very rare ~15 miles)
    return v

def tcol(h, coastal=False):
    """Colours: deep ocean → tidal flat → sandy beach (coast only) → grass → heather → fell."""
    if h<WATER_Y-0.5:
        d=min(1.0,(WATER_Y-0.5-h)/8.0)
        return (0.08+d*0.03, 0.16+d*0.06, 0.32+d*0.10)
    if h<WATER_Y+0.15:                               # intertidal / tidal flat
        return (0.62,0.56,0.40)
    if coastal and h<WATER_Y+1.6:                    # sandy beach – coast only, never inland
        t=(h-WATER_Y-0.15)/1.45
        return (0.80-t*0.10, 0.70-t*0.12, 0.44-t*0.10)
    if h<5.0:
        t=max(0.,min(1.,(h-WATER_Y-1.6)/3.4))
        return (0.30+t*.06, 0.42+t*.02, 0.22+t*.01)
    if h<30.0:
        t=(h-5.0)/25.0
        return (0.33+t*.09, 0.40-t*.08, 0.22-t*.04)
    if h<120.0:
        t=(h-30.0)/90.0
        return (0.42+t*.10, 0.26-t*.04, 0.28+t*.06)
    if h<280.0:
        t=(h-120.0)/160.0
        return (0.52+t*.05, 0.22-t*.03, 0.32-t*.07)
    t=min(1.0,(h-280.0)/320.0)
    return (0.55+t*.14, 0.50+t*.08, 0.48+t*.08)

WCOL=SEA_COL    # all water surfaces use ocean blue

def th_s(x,z):
    """Smooth terrain for road routing – includes coastal biome."""
    cn=_cn(x,z)
    if cn<COAST_SEA:
        d=min(1.0,(COAST_SEA-cn)/0.22)
        return WATER_Y-1.0-d*9.0
    if cn<COAST_BEACH:
        t=(cn-COAST_SEA)/(COAST_BEACH-COAST_SEA)
        return WATER_Y+0.05+t*3.5
    inland_s=min(1.0,(cn-COAST_BEACH)/0.12)
    mac=pn(x*0.0014,z*0.0014); hil=pn(x*0.006,z*0.006,oc=2,pe=0.48)
    if mac<-0.48: return (-3.0+mac*4.0)*max(0.2,inland_s)  # inland lake (very rare)
    if mac<0.08:  return (hil*(3.0+(mac+0.28)/0.36*7.0))*inland_s
    if mac<0.40:  return hil*(20.0+(mac-0.08)/0.32*60.0)+mac*20.0
    if mac<0.65:  return hil*(80.0+(mac-0.40)/0.25*150.0)+mac*40.0
    return hil*(200.0+min(1.0,(mac-0.65)/0.20)*300.0)+mac*60.0

_THC:dict={}; _THCG=2.0
def th_c(x,z):
    k=(int(round(x/_THCG)),int(round(z/_THCG)))
    v=_THC.get(k)
    if v is None:
        if len(_THC)>40_000: _THC.clear()
        _THC[k]=v=th(k[0]*_THCG,k[1]*_THCG)
    return v

_NE=3.5
def terrain_normal(x,z):
    hL=th_s(x-_NE,z); hR=th_s(x+_NE,z)
    hB=th_s(x,z-_NE); hF=th_s(x,z+_NE)
    tx=np.array([2.*_NE,hR-hL,0.]); tz=np.array([0.,hF-hB,2.*_NE])
    n=np.cross(tz,tx); nl=np.linalg.norm(n)
    return n/nl if nl>1e-6 else np.array([0.,1.,0.])

# ═══════════════════════════════════════════════════════
#  ROAD SPLINE
# ═══════════════════════════════════════════════════════
class Road:
    def __init__(self):
        self.pts=[]; self.tans=[]; self.nors=[]; self._br=[]
        self._ang=0.; self._pos=np.zeros(3,dtype=np.float64)
        self._grow(DRAW_BH+DRAW_AH+80)

    def _grow(self,tgt):
        while len(self.pts)<tgt:
            i=len(self.pts)
            self._ang+=pn(i*0.008,2.7)*0.055
            dx=math.sin(self._ang)*SEG_L; dz=-math.cos(self._ang)*SEG_L
            nxt=self._pos+np.array([dx,0.,dz])
            offsets=[(ox,oz) for ox in(-10,0,10) for oz in(-10,0,10)]
            h_avg=sum(th_s(float(nxt[0]+ox),float(nxt[2]+oz)) for ox,oz in offsets)/9.
            if not hasattr(self,'_hb'): self._hb=h_avg
            # allow faster descent (-0.32) than ascent (+0.22) so hills don't keep road elevated
            self._hb+=max(-0.32,min(0.22,(h_avg-self._hb)*0.10))
            mac_here=_mac(float(nxt[0]),float(nxt[2]))
            over_water=(mac_here<-0.50)   # true ocean only; beaches/lakes handled as land
            ty=(WATER_Y+BRDG_CLR) if over_water else max(WATER_Y+0.05, self._hb+0.12)
            dy=max(-0.32,min(0.22,(ty-float(self._pos[1]))*0.10))
            new=self._pos+np.array([dx,dy,dz])
            if not over_water:
                g2=th_s(float(new[0]),float(new[2]))
                abs_floor=g2+0.05 if g2>WATER_Y else WATER_Y+BRDG_CLR
                if new[1]<abs_floor:
                    new[1]=min(abs_floor, float(new[1])+0.22)
                self._hb=float(new[1])   # track actual height – don't lock at peak
            tan=new-self._pos; tan/=np.linalg.norm(tan)+1e-9
            nor=np.array([tan[2],0.,-tan[0]]); nor/=np.linalg.norm(nor)+1e-9
            self.pts.append(new.copy()); self.tans.append(tan.copy())
            self.nors.append(nor.copy()); self._br.append(over_water)
            self._pos=new

    def get(self,i):
        self._grow(i+40); return self.pts[i],self.tans[i],self.nors[i]
    def bridge(self,i):
        self._grow(i+40); return self._br[i] if i<len(self._br) else False

# ═══════════════════════════════════════════════════════
#  PLAYER
# ═══════════════════════════════════════════════════════
def _nearest_seg(pos,road,hint,win=60):
    px,pz=float(pos[0]),float(pos[2])
    road.get(hint+win+10)
    bi,bd=hint,1e18
    for i in range(max(0,hint-win//3),hint+win):
        p=road.get(i)[0]
        d=(float(p[0])-px)**2+(float(p[2])-pz)**2
        if d<bd: bd=d; bi=i
    return bi

class Player:
    def __init__(self,road,veh='focus'):
        p0,t0,_=road.get(5)
        self.pos=p0.copy()
        self.pos[1]=max(WATER_Y,th_s(*map(float,[p0[0],p0[2]])))+0.08
        self.heading=math.atan2(float(t0[0]),-float(t0[2]))
        self.speed=0.; self.steer=0.
        self.veh=veh; self.near=5
        self.surf_up=np.array([0.,1.,0.])
        self.at_boundary=0.

    def update(self,road,keys,dt):
        c=VCFG[self.veh]
        if keys[K_UP] or keys[K_w]:
            self.speed=min(c['ms'],self.speed+c['ac']*dt)
        elif keys[K_DOWN] or keys[K_s]:
            self.speed=(max(0.,self.speed-c['br']*dt) if self.speed>0.3
                        else max(-c['mr'],self.speed-c['ac']*0.55*dt))
        else:
            self.speed*=1.-min(1.,c['dr']*dt)
            if abs(self.speed)<0.05: self.speed=0.
        si=0.
        if keys[K_LEFT]  or keys[K_a]: si=-1.
        if keys[K_RIGHT] or keys[K_d]: si= 1.
        self.steer+=(si-self.steer)*min(1.,6.*dt)
        v_eff=math.copysign(min(abs(self.speed),9.),self.speed)
        self.heading+=self.steer*math.radians(c['wb']*4.5)/c['wb']*v_eff*dt
        fv=np.array([math.sin(self.heading),0.,-math.cos(self.heading)])
        self.pos=self.pos+fv*self.speed*dt
        px,pz=float(self.pos[0]),float(self.pos[2])
        self.near=_nearest_seg(self.pos,road,self.near)
        rp,_,rn=road.get(self.near)
        xzd=math.hypot(px-float(rp[0]),pz-float(rp[2]))
        on_road=xzd<ROAD_W*0.55
        br=road.bridge(self.near)
        if on_road:
            ty=float(rp[1])+c['gd']
        elif br:
            ty=max(WATER_Y, th_c(px,pz))+c['gd']
        else:
            edge_d=max(0., xzd-ROAD_W*0.5)
            gnd_raw=th_c(px,pz)
            h=_blended_h(gnd_raw, float(rp[1]), edge_d, br)
            ty=max(WATER_Y, h)+c['gd']
        self.pos[1]+=(ty-self.pos[1])*min(1.,18.*dt)
        tn=terrain_normal(px,pz)
        self.surf_up+=(tn-self.surf_up)*min(1.,8.*dt)
        sl=np.linalg.norm(self.surf_up)
        if sl>1e-6: self.surf_up/=sl
        diff=self.pos-rp; lat=float(np.dot(diff,rn))
        lat_abs=abs(lat)
        # ── bridge barrier collision: slide along wall ────
        if br and lat_abs>ROAD_W*0.5:
            self.pos-=rn*(lat-math.copysign(ROAD_W*0.5,lat))
            fv=self.fwd()
            _,rt,_=road.get(self.near)
            # component of forward-vec pressing into the barrier
            vn_into=float(np.dot(fv,rn))*math.copysign(1.,lat)
            if vn_into>0.05:           # actually pressing into wall
                # redirect heading to slide along the road tangent
                vt=float(np.dot(fv,rt))
                slide=rt if vt>=0. else -rt
                new_h=math.atan2(float(slide[0]),-float(slide[2]))
                dh=new_h-self.heading
                while dh> math.pi: dh-=2*math.pi
                while dh<-math.pi: dh+=2*math.pi
                self.heading+=dh*min(1.,vn_into*2.5)
                # small speed scrub proportional to impact angle
                self.speed*=max(0.75,1.-vn_into*0.35)
            lat=math.copysign(ROAD_W*0.5,lat); lat_abs=ROAD_W*0.5
        # ── world boundary ────────────────────────────────
        self.at_boundary=max(0.,min(1.,(lat_abs-MAX_LAT*0.7)/(MAX_LAT*0.3)))
        if lat_abs>MAX_LAT:
            self.pos-=rn*(lat-math.copysign(MAX_LAT,lat))

    def fwd(self):
        return np.array([math.sin(self.heading),0.,-math.cos(self.heading)])
    def rgt(self):
        return np.array([math.cos(self.heading),0., math.sin(self.heading)])
    def sfwd(self):
        f=self.fwd(); n=self.surf_up
        fp=f-n*float(np.dot(f,n)); fl=np.linalg.norm(fp)
        return fp/fl if fl>1e-6 else f
    def srgt(self):
        r=np.cross(self.sfwd(),self.surf_up); rl=np.linalg.norm(r)
        return r/rl if rl>1e-6 else self.rgt()
    def lean(self):
        return -self.steer*min(1.,abs(self.speed)/5.)*22.

# ═══════════════════════════════════════════════════════
#  CAMERA
# ═══════════════════════════════════════════════════════
class Camera:
    def __init__(self):
        self._eye=np.zeros(3); self._at=np.zeros(3)
        self.oyaw=0.; self.opitch=0.; self._cb=12.; self._cu=4.5
        self.zoom=1.0
        self.mode=0   # 0=follow  1=front-cam
        self._tilt=0. # smooth roll for front cam (motorbike/turning)

    def setveh(self,v):
        self._cb=float(VCFG[v]['cb']); self._cu=float(VCFG[v]['cu'])

    def update(self,pl,dt):
        c=VCFG[pl.veh]
        f=pl.sfwd(); up=pl.surf_up
        if self.mode==0:
            # ── follow cam ───────────────────────────────
            back=np.array([-f[0],0.,-f[2]]); bl=np.linalg.norm(back)
            if bl>1e-6: back/=bl
            we=pl.pos+back*self._cb*self.zoom+np.array([0.,self._cu*self.zoom,0.])
            wa=pl.pos+f*5.
            self._tilt*=(1.-min(1.,6.*dt))
        else:
            # ── front cam: driver's-eye at front of vehicle ──
            # fwd_z = forward offset from vehicle centre to driver seat
            # fwd_h = eye height above pl.pos (which is ground+gd)
            fwd_h=float(c.get('fwd_h',1.10)); fwd_z=float(c.get('fwd_z',0.90))
            we=pl.pos + f*fwd_z + up*fwd_h
            wa=pl.pos + f*(fwd_z+20.)         # look 20 m ahead
            tgt_tilt=pl.steer*min(1.,abs(pl.speed)/6.)*7.0
            self._tilt+=(tgt_tilt-self._tilt)*min(1.,8.*dt)
        a=min(1.,10.*dt)
        self._eye+=(we-self._eye)*a; self._at+=(wa-self._at)*a

    def apply(self):
        arm=self._eye-self._at
        yr=math.radians(self.oyaw); cy,sy=math.cos(yr),math.sin(yr)
        arm=np.array([cy*arm[0]+sy*arm[2],arm[1],-sy*arm[0]+cy*arm[2]])
        rgt=np.cross(arm,[0.,1.,0.]); rl=np.linalg.norm(rgt)
        if rl<1e-6: rgt=np.array([1.,0.,0.])
        else: rgt/=rl
        pr=math.radians(self.opitch); cp,sp=math.cos(pr),math.sin(pr)
        arm=arm*cp+np.cross(rgt,arm)*sp+rgt*float(np.dot(rgt,arm))*(1.-cp)
        eye=self._at+arm
        # tilt (roll) for front cam
        tilt_r=math.radians(self._tilt) if self.mode==1 else 0.
        ct,st=math.cos(tilt_r),math.sin(tilt_r)
        fwd_n=arm/max(1e-6,np.linalg.norm(arm))
        right=np.cross(fwd_n,[0.,1.,0.]); right/=max(1e-6,np.linalg.norm(right))
        world_up=np.array([0.,1.,0.])
        cam_up=world_up*ct+right*st
        glLoadIdentity()
        gluLookAt(float(eye[0]),float(eye[1]),float(eye[2]),
                  float(self._at[0]),float(self._at[1]),float(self._at[2]),
                  float(cam_up[0]),float(cam_up[1]),float(cam_up[2]))

# ═══════════════════════════════════════════════════════
#  SKY
# ═══════════════════════════════════════════════════════
def draw_sky():
    glDisable(GL_DEPTH_TEST); glDisable(GL_LIGHTING); glDisable(GL_FOG)
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity(); glOrtho(0,1,0,1,-1,1)
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity()
    glBegin(GL_QUADS)
    glColor3f(*SKY_BOT); glVertex2f(0,0); glVertex2f(1,0)
    glColor3f(*SKY_TOP); glVertex2f(1,1); glVertex2f(0,1)
    glEnd()
    glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW); glPopMatrix()
    glEnable(GL_DEPTH_TEST); glEnable(GL_LIGHTING); glEnable(GL_FOG)

# ═══════════════════════════════════════════════════════
#  SEA PLANE  –  flat ocean background behind terrain strips
# ═══════════════════════════════════════════════════════
def draw_sea(player_pos):
    """Flat ocean at WATER_Y-0.05 – slightly below terrain clamp so no z-fighting."""
    px,pz=float(player_pos[0]),float(player_pos[2])
    glDisable(GL_LIGHTING); glEnable(GL_FOG)
    glColor3f(*SEA_COL); glNormal3f(0,1,0)
    SR=FAR*0.94
    glBegin(GL_QUADS)
    glVertex3f(px-SR,WATER_Y-0.05,pz-SR); glVertex3f(px+SR,WATER_Y-0.05,pz-SR)
    glVertex3f(px+SR,WATER_Y-0.05,pz+SR); glVertex3f(px-SR,WATER_Y-0.05,pz+SR)
    glEnd()
    glEnable(GL_LIGHTING)

