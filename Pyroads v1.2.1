#  HONDA CB500F  (silver/black sport-tourer)
# ═══════════════════════════════════════════════════════
def draw_honda_cb(pp,fw,rg,lean=0.):
    lr=math.radians(lean); world_up=np.array([0.,1.,0.])
    cl,sl=math.cos(lr),math.sin(lr)
    up_v=world_up*cl-rg*sl; ul=np.linalg.norm(up_v)
    if ul>1e-6: up_v/=ul
    rg2=np.cross(fw,up_v); rl=np.linalg.norm(rg2)
    if rl>1e-6: rg2/=rl
    up=np.cross(rg2,fw); ul=np.linalg.norm(up)
    if ul>1e-6: up/=ul
    m=(float(rg2[0]),float(rg2[1]),float(rg2[2]),0,
       float(up[0]), float(up[1]), float(up[2]), 0,
       float(fw[0]), float(fw[1]), float(fw[2]), 0,
       float(pp[0]), float(pp[1]), float(pp[2]), 1)
    glPushMatrix(); glMultMatrixf(m)
    WR,WW=0.30,0.14
    glColor3f(0.14,0.14,0.16); _box(0,.72, 0, .10,.22,1.52)
    glColor3f(0.24,0.24,0.26); _box(0,.50, .14, .32,.34,.86)
    glColor3f(0.18,0.18,0.20); _box(0,.36, .14, .26,.18,.82)
    glColor3f(0.68,0.70,0.72); _box(0,.98,.24, .28,.30,.72)
    glColor3f(0.12,0.12,0.14)
    _box( .15,.98,.24, .06,.30,.68); _box(-.15,.98,.24, .06,.30,.68)
    glColor3f(0.10,0.10,0.12); _box(0,.90,-.38, .24,.16,.72)
    glColor3f(0.14,0.14,0.16); _box(0,.86,-.88, .20,.10,.36)
    glColor3f(0.64,0.66,0.68); _box(0,.80,-.96, .18,.20,.32)
    glColor3f(0.88,0.06,0.06); _box(0,.80,-1.12, .18,.14,.06)
    glColor3f(0.68,0.70,0.72); _box(0,.98,.88, .26,.24,.36)
    glColor3f(0.92,0.96,0.98); _box(0,.92,1.10, .24,.22,.08)
    glColor3f(1.0,0.96,0.82); _box(0,1.06,1.12, .20,.06,.06)
    glColor3f(0.20,0.28,0.42); _box(0,1.12,1.02, .22,.14,.06)
    glColor3f(0.46,0.46,0.48); _box(0,1.10,.82, .88,.07,.08)
    glColor3f(0.12,0.12,0.14)
    _box( .46,1.10,.82, .06,.08,.10); _box(-.46,1.10,.82, .06,.08,.10)
    glColor3f(0.58,0.58,0.62)
    _box( .12,.60,.88, .06,.80,.08); _box(-.12,.60,.88, .06,.80,.08)
    glColor3f(0.20,0.20,0.22); _box(0,.52,-.52, .08,.10,.72)
    glColor3f(0.54,0.52,0.46); _box(.20,.36,.26, .06,.08,1.06)
    glColor3f(0.62,0.60,0.54); _box(.20,.32,-.72, .14,.12,.24)
    glColor3f(0.88,0.88,0.92)
    _box( .15,.98,.10, .04,.10,.14); _box(-.15,.98,.10, .04,.10,.14)
    glColor3f(0.11,0.11,0.12)
    _whl(0,WR,.88,WR,WW); _whl(0,WR,-.82,WR,WW)
    glColor3f(0.55,0.55,0.58)
    _whl(0,WR,.88,WR*.58,WW+.02,8); _whl(0,WR,-.82,WR*.58,WW+.02,8)
    glPopMatrix()

