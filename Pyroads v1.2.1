# ═══════════════════════════════════════════════════════
#  SPEEDOMETER HUD  –  mph  +  pygame font text
# ═══════════════════════════════════════════════════════
_SPD_MAX={'focus':120,'civic':150,'gemini2':60,'levante':70,'daf':60,'honda_cb':130}   # mph
_SPD_COLS=[(0,50,'#1db84a'),(50,80,'#e6c014'),(80,200,'#e03030')]

def _hex(s): r=int(s[1:3],16)/255; g=int(s[3:5],16)/255; b=int(s[5:7],16)/255; return r,g,b

def _ring_arc(cx,cy,r,a0,a1,thick,segs=48):
    glBegin(GL_QUAD_STRIP)
    for i in range(segs+1):
        a=a0+(a1-a0)*i/segs; ca,sa=math.cos(a),math.sin(a)
        glVertex2f(cx+(r-thick)*ca, cy+(r-thick)*sa)
        glVertex2f(cx+r*ca,          cy+r*sa)
    glEnd()

def _filled_circle(cx,cy,r,segs=32):
    glBegin(GL_TRIANGLE_FAN); glVertex2f(cx,cy)
    for i in range(segs+1):
        a=2*math.pi*i/segs; glVertex2f(cx+r*math.cos(a),cy+r*math.sin(a))
    glEnd()

# ── pygame font → GL texture cache ──────────────────────────────
_TXT_CACHE: dict = {}
def _draw_text_hud(text, cx, cy, size=38, color=(230,240,200,255)):
    """Render text centred at (cx,cy) in current 2-D ortho projection."""
    key=(text,size,color)
    if key not in _TXT_CACHE:
        if len(_TXT_CACHE)>400:
            for tex,_,_ in _TXT_CACHE.values(): glDeleteTextures([tex])
            _TXT_CACHE.clear()
        font=pygame.font.SysFont('consolas,courier new,monospace',size,bold=True)
        surf=font.render(text,True,color[:3])
        surf=surf.convert_alpha()
        tw,th=surf.get_size()
        raw=pygame.image.tostring(surf,'RGBA',True)
        tex=glGenTextures(1)
        glBindTexture(GL_TEXTURE_2D,tex)
        glTexImage2D(GL_TEXTURE_2D,0,GL_RGBA,tw,th,0,GL_RGBA,GL_UNSIGNED_BYTE,raw)
        glTexParameteri(GL_TEXTURE_2D,GL_TEXTURE_MIN_FILTER,GL_LINEAR)
        glTexParameteri(GL_TEXTURE_2D,GL_TEXTURE_MAG_FILTER,GL_LINEAR)
        _TXT_CACHE[key]=(tex,tw,th)
    tex,tw,th=_TXT_CACHE[key]
    x,y=cx-tw/2.,cy-th/2.
    glEnable(GL_TEXTURE_2D); glBindTexture(GL_TEXTURE_2D,tex)
    glColor4f(1,1,1,1)
    glBegin(GL_QUADS)
    glTexCoord2f(0,0);glVertex2f(x,y)
    glTexCoord2f(1,0);glVertex2f(x+tw,y)
    glTexCoord2f(1,1);glVertex2f(x+tw,y+th)
    glTexCoord2f(0,1);glVertex2f(x,y+th)
    glEnd()
    glDisable(GL_TEXTURE_2D)
    return tw,th

def draw_speedometer(player):
    spd_mph = abs(player.speed)*2.23694
    max_s   = float(_SPD_MAX.get(player.veh,140))
    frac    = min(1.0, spd_mph/max_s)
    cx=WIN_W-118.; cy=118.; R=78.; thick=13.

    glDisable(GL_DEPTH_TEST); glDisable(GL_LIGHTING); glDisable(GL_FOG)
    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA,GL_ONE_MINUS_SRC_ALPHA)
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity()
    glOrtho(0,WIN_W,0,WIN_H,-1,1)
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity()

    # bezel + dark disc
    glColor4f(0.24,0.26,0.30,1.0); _filled_circle(cx,cy,R+thick+8)
    glColor4f(0.06,0.06,0.10,1.0); _filled_circle(cx,cy,R+thick+4)

    A0=math.radians(225.); SWEEP=math.radians(-270.)

    # dim track
    glColor4f(0.20,0.20,0.22,1.0)
    _ring_arc(cx,cy,R+thick,A0,A0+SWEEP,thick)

    # colour arc
    for lo,hi,col in _SPD_COLS:
        f_lo=lo/max_s; f_hi=min(hi,max_s)/max_s
        if frac<=f_lo: break
        ta=A0+f_lo*SWEEP; tb=A0+min(frac,f_hi)*SWEEP
        glColor3f(*_hex(col)); _ring_arc(cx,cy,R+thick,ta,tb,thick)

    # tick marks
    step=10
    for v in range(0,int(max_s)+1,step):
        ang=A0+(v/max_s)*SWEEP; ca,sa=math.cos(ang),math.sin(ang)
        maj=(v%(step*4)==0)
        inner=R-6 if maj else R
        glColor3f(0.88,0.88,0.88) if maj else glColor3f(0.38,0.38,0.42)
        glLineWidth(2.5 if maj else 1.2)
        glBegin(GL_LINES)
        glVertex2f(cx+inner*ca,cy+inner*sa)
        glVertex2f(cx+(R+thick)*ca,cy+(R+thick)*sa)
        glEnd()
    glLineWidth(1.)

    # needle
    nang=A0+frac*SWEEP; nca,nsa=math.cos(nang),math.sin(nang)
    glColor4f(0,0,0,0.55); glLineWidth(6.)
    glBegin(GL_LINES)
    glVertex2f(cx-nca*16+1,cy-nsa*16-1); glVertex2f(cx+nca*(R-5)+1,cy+nsa*(R-5)-1)
    glEnd()
    glColor3f(1.0,0.28,0.08); glLineWidth(3.)
    glBegin(GL_LINES)
    glVertex2f(cx-nca*16,cy-nsa*16); glVertex2f(cx+nca*(R-5),cy+nsa*(R-5))
    glEnd()
    glLineWidth(1.)

    # hub
    glColor3f(0.14,0.14,0.18); _filled_circle(cx,cy,12)
    glColor3f(1.0,0.28,0.08);  _filled_circle(cx,cy,6)

    # ── digital mph readout using font ───────────────────────
    lbl=str(int(spd_mph))
    # dark pill background
    pad=10.; dw,dh=len(lbl)*26.+pad*2, 52.
    px0=cx-dw/2.; py0=cy-38.
    glColor4f(0.06,0.06,0.10,0.92)
    glBegin(GL_QUADS)
    glVertex2f(px0,py0); glVertex2f(px0+dw,py0)
    glVertex2f(px0+dw,py0+dh); glVertex2f(px0,py0+dh)
    glEnd()
    # speed number
    _draw_text_hud(lbl, cx, py0+dh*0.54, size=42, color=(240,255,180,255))
    # 'mph' label
    _draw_text_hud('mph', cx, py0-10., size=18, color=(160,168,180,255))

    glDisable(GL_BLEND)
    glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW);  glPopMatrix()
    glEnable(GL_DEPTH_TEST); glEnable(GL_LIGHTING); glEnable(GL_FOG)

# ═══════════════════════════════════════════════════════
#  BOUNDARY WARNING VIGNETTE
# ═══════════════════════════════════════════════════════
def draw_boundary_flash(intensity):
    if intensity<=0.: return
    glDisable(GL_DEPTH_TEST); glDisable(GL_LIGHTING); glDisable(GL_FOG)
    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA,GL_ONE_MINUS_SRC_ALPHA)
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity(); glOrtho(0,WIN_W,0,WIN_H,-1,1)
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity()
    a=intensity*0.55; bw=80
    glColor4f(0.8,0.1,0.05,a)
    for (x0,y0,x1,y1) in [(0,0,WIN_W,bw),(0,WIN_H-bw,WIN_W,WIN_H),
                           (0,0,bw,WIN_H),(WIN_W-bw,0,WIN_W,WIN_H)]:
        glBegin(GL_QUADS)
        glVertex2f(x0,y0); glVertex2f(x1,y0); glVertex2f(x1,y1); glVertex2f(x0,y1)
        glEnd()
    glDisable(GL_BLEND)
    glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW); glPopMatrix()
    glEnable(GL_DEPTH_TEST); glEnable(GL_LIGHTING); glEnable(GL_FOG)

# ═══════════════════════════════════════════════════════
#  VEHICLE SELECTOR HUD
# ═══════════════════════════════════════════════════════
_VCOLS={'focus':(0.70,0.72,0.74),'civic':(0.76,0.08,0.10),
        'gemini2':(0.82,0.06,0.07),'levante':(0.92,0.92,0.94),
        'daf':(0.14,0.26,0.54),'honda_cb':(0.66,0.68,0.70)}

def draw_hud(current):
    glDisable(GL_DEPTH_TEST); glDisable(GL_LIGHTING); glDisable(GL_FOG)
    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA,GL_ONE_MINUS_SRC_ALPHA)
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity(); glOrtho(0,WIN_W,0,WIN_H,-1,1)
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity()
    tw,gap,bh,sh=72,8,20,32
    total=(6*tw+5*gap); x0=(WIN_W-total)//2
    for idx,vn in enumerate(VNAMES):
        x=x0+idx*(tw+gap); sel=(vn==current); h=sh if sel else bh
        r,g,b=_VCOLS[vn]
        glColor4f(r*.25,g*.25,b*.25,0.78)
        glBegin(GL_QUADS)
        glVertex2f(x,0); glVertex2f(x+tw,0); glVertex2f(x+tw,h); glVertex2f(x,h)
        glEnd()
        stripe=7 if sel else 3
        glColor4f(r,g,b,1.0)
        glBegin(GL_QUADS)
        glVertex2f(x,h-stripe); glVertex2f(x+tw,h-stripe)
        glVertex2f(x+tw,h);     glVertex2f(x,h)
        glEnd()
        glColor4f(0.85,0.85,0.85,0.9)
        kx=x+5; ky=h-stripe-11
        glBegin(GL_QUADS)
        glVertex2f(kx,ky); glVertex2f(kx+9,ky); glVertex2f(kx+9,ky+8); glVertex2f(kx,ky+8)
        glEnd()
    glDisable(GL_BLEND)
    glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW); glPopMatrix()
    glEnable(GL_DEPTH_TEST); glEnable(GL_LIGHTING); glEnable(GL_FOG)

# ═══════════════════════════════════════════════════════
#  OPENGL SETUP
# ═══════════════════════════════════════════════════════
def setup_gl(w,h):
    global WIN_W,WIN_H; WIN_W,WIN_H=w,h
    glClearColor(*SKY_BOT,1.)
    glEnable(GL_DEPTH_TEST); glDepthFunc(GL_LEQUAL)
    glEnable(GL_LIGHTING);   glEnable(GL_LIGHT0)
    glEnable(GL_COLOR_MATERIAL)
    glColorMaterial(GL_FRONT_AND_BACK,GL_AMBIENT_AND_DIFFUSE)
    glLightfv(GL_LIGHT0,GL_POSITION,[0.5,1.,0.4,0.])
    glLightfv(GL_LIGHT0,GL_DIFFUSE, [0.88,0.88,0.82,1.])
    glLightfv(GL_LIGHT0,GL_AMBIENT, [0.30,0.30,0.34,1.])
    glLightfv(GL_LIGHT0,GL_SPECULAR,[0.,0.,0.,1.])
    glEnable(GL_FOG); glFogi(GL_FOG_MODE,GL_EXP2)
    glFogfv(GL_FOG_COLOR,FOG_COL); glFogf(GL_FOG_DENSITY,0.0072)
    glFogf(GL_FOG_START,80.); glFogf(GL_FOG_END,360.)
    glHint(GL_FOG_HINT,GL_NICEST)
    glViewport(0,0,w,h)
    glMatrixMode(GL_PROJECTION); glLoadIdentity()
    gluPerspective(FOV,w/h,NEAR,FAR)
    glMatrixMode(GL_MODELVIEW)

# ═══════════════════════════════════════════════════════
#  MAIN LOOP
# ═══════════════════════════════════════════════════════
def main():
    global WIN_W, WIN_H
    pygame.init()
    pygame.font.init()
    info = pygame.display.Info()
    native_w, native_h = info.current_w, info.current_h
    fullscreen = True
    flags = DOUBLEBUF|OPENGL|FULLSCREEN
    pygame.display.set_mode((native_w, native_h), flags)
    pygame.display.set_caption("Slow Roads UK  ·  F11=window  ·  ESC=quit")
    clock = pygame.time.Clock()
    setup_gl(native_w, native_h)

    road   = Road()
    player = Player(road,'focus')
    cam    = Camera(); cam.setveh('focus')
    p0,t0,_=road.get(5)
    back0=np.array([-t0[0],0.,-t0[2]]); back0/=np.linalg.norm(back0)+1e-9
    cam._eye=p0+back0*cam._cb+np.array([0.,cam._cu,0.])
    cam._at =p0+t0*5.

    rclick=False; frame=0

    while True:
        dt=min(clock.tick(60)/1000.,0.05); frame+=1

        for ev in pygame.event.get():
            if ev.type==QUIT: pygame.quit(); sys.exit()
            if ev.type==KEYDOWN:
                if ev.key==K_ESCAPE: pygame.quit(); sys.exit()
                if ev.key==K_F11:
                    fullscreen = not fullscreen
                    if fullscreen:
                        pygame.display.set_mode((native_w,native_h), DOUBLEBUF|OPENGL|FULLSCREEN)
                        setup_gl(native_w, native_h)
                    else:
                        ww,wh = min(native_w,1280), min(native_h,720)
                        pygame.display.set_mode((ww,wh), DOUBLEBUF|OPENGL|RESIZABLE)
                        setup_gl(ww, wh)
                vm={K_1:'focus',K_2:'civic',K_3:'gemini2',K_4:'levante',K_5:'daf',K_6:'honda_cb'}
                if ev.key in vm:
                    nv=vm[ev.key]
                    if nv!=player.veh: player.veh=nv; cam.setveh(nv)
                if ev.key==K_c:
                    cam.mode=1-cam.mode
                    cam._tilt=0.
                    if cam.mode==0: cam.oyaw=0.; cam.opitch=0.
            if ev.type==VIDEORESIZE:
                setup_gl(ev.w, ev.h)
            if ev.type==MOUSEBUTTONDOWN and ev.button==3:
                rclick=True; pygame.mouse.get_rel()
            if ev.type==MOUSEBUTTONUP and ev.button==3: rclick=False
            if ev.type==MOUSEMOTION and rclick:
                rx,ry=ev.rel
                cam.oyaw  -=rx*0.35
                cam.opitch=max(-28.,min(52.,cam.opitch+ry*0.28))
            # scrollwheel zoom (pygame 2: MOUSEWHEEL; pygame 1: buttons 4/5)
            if ev.type==MOUSEWHEEL:
                cam.zoom=max(0.35,min(4.0,cam.zoom-ev.y*0.12))
            if ev.type==MOUSEBUTTONDOWN:
                if ev.button==4: cam.zoom=max(0.35,cam.zoom-0.12)
                if ev.button==5: cam.zoom=min(4.0, cam.zoom+0.12)

        if not rclick:
            decay=1.-min(1.,3.5*dt)
            cam.oyaw*=decay; cam.opitch*=decay

        keys=pygame.key.get_pressed()
        player.update(road,keys,dt)
        cam.update(player,dt)

        if frame%30==0:
            mph=abs(player.speed)*2.23694
            mode="FS" if fullscreen else "Win"
            cam_label="FrontCam" if cam.mode==1 else "Follow"
            pygame.display.set_caption(
                f"Slow Roads UK  ·  {player.veh}  ·  "
                f"{mph:.0f} mph  ·  1-6=veh  C=cam({cam_label})  F11={mode}  ESC=quit")

        glClear(GL_COLOR_BUFFER_BIT)
        draw_sky()
        glClear(GL_DEPTH_BUFFER_BIT)
        cam.apply()
        glLightfv(GL_LIGHT0,GL_POSITION,[0.5,1.,0.4,0.])

        ci=player.near
        global _FRONT_CAM; _FRONT_CAM=(cam.mode==1)
        draw_sea(player.pos)
        draw_terrain(road,ci)
        draw_road(road,ci)
        draw_bridges(road,ci)
        draw_vehicle(player)
        draw_trees(player.pos, road, player.near)

        draw_boundary_flash(player.at_boundary)
        draw_speedometer(player)
        draw_hud(player.veh)

        pygame.display.flip()

if __name__=="__main__":
    main()