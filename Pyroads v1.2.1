        for wx in(1.58,-1.58): _whl(wx,WY,wz,WR,WW*0.68)
    glColor3f(0.60,0.60,0.63)
    for wx in(1.28,-1.28): _whl(wx,WY,4.20,WR*.54,WW+.02,8)
    for wz in(-1.60,-2.70,-7.00,-8.00):
        for wx in(1.36,-1.36): _whl(wx,WY,wz,WR*.54,WW+.02,8)
    glPopMatrix()

