# Large-scale coast noise (wavelength ~2.8 km) – drives coastal biome
def _cn(x,z): return pn(x*0.000360, z*0.000360)
COAST_SEA   = -0.20   # below this → open ocean
COAST_BEACH = -0.04   # below this → beach/dune transition

SKY_TOP=(0.50,0.58,0.72)
SKY_BOT=(0.68,0.72,0.80)
FOG_COL=[0.68,0.72,0.80,1.0]

